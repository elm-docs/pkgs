[
    {
        "name": "Html.Styled.Attributes.Aria",
        "comment": " An ongoing effor to port all Aria attributes to elm-css.\n\n**NOTE** Some Aria attributes have HTML 5 counterparts with the same\nsemantic, like `aria-required` and `required`. These kind of attributes are\nintentionally not include here.\n\n\n# Primary\n\n@docs label, role\n\n\n# Relationships\n\n@docs IdReference, describedBy, labeledBy\n\n\n# Widget states and properties\n\n@docs expanded, hasPopup, invalid\n\n\n# User interface properties\n\n@docs hidden\n\n",
        "unions": [],
        "aliases": [
            {
                "name": "IdReference",
                "comment": " Reference to the ID of another element in the same document. More info at\n<https://www.w3.org/TR/wai-aria/#valuetype_idref>.\n",
                "args": [],
                "type": "String"
            }
        ],
        "values": [
            {
                "name": "describedBy",
                "comment": " Identifies the element (or elements) that describes the object. More info at\n<https://www.w3.org/TR/wai-aria/#aria-describedby>.\n",
                "type": "List IdReference -> Attribute msg"
            },
            {
                "name": "expanded",
                "comment": " Indicates whether the element, or another grouping element it controls, is\ncurrently expanded or collapsed. More info at\n<https://www.w3.org/TR/wai-aria/#aria-expanded>.\n",
                "type": "Bool -> Attribute msg"
            },
            {
                "name": "hasPopup",
                "comment": " Indicates the availability and type of interactive popup element, such as\nmenu or dialog, that can be triggered by an element.\n<https://www.w3.org/TR/wai-aria/#aria-haspopup>.\n",
                "type": "Popup -> Attribute msg"
            },
            {
                "name": "hidden",
                "comment": " Indicates whether the element is exposed to an accessibility API. More info\nat <https://www.w3.org/TR/wai-aria/#aria-hidden>.\n**NOTE**: Authors are advised to use extreme caution and consider a wide range\nof disabilities when hiding visibly rendered content from assistive\ntechnologies.\n",
                "type": "Bool -> Attribute msg"
            },
            {
                "name": "invalid",
                "comment": " Indicates the entered value does not conform to the format expected by the\napplication. More info at <https://www.w3.org/TR/wai-aria/#aria-invalid>\n",
                "type": "Invalid -> Attribute msg"
            },
            {
                "name": "label",
                "comment": " Defines a string value that labels the current element. More info at\n<https://www.w3.org/TR/wai-aria/#aria-label>.\n",
                "type": "String -> Attribute msg"
            },
            {
                "name": "labeledBy",
                "comment": " Identifies the element (or elements) that labels the current element. More\ninfo at <https://www.w3.org/TR/wai-aria/#aria-labelby>.\n",
                "type": "List IdReference -> Attribute msg"
            },
            {
                "name": "role",
                "comment": " Sets the type of an element. More info at\n<https://www.w3.org/TR/html-aria/#allowed-aria-roles-states-and-properties>.\n",
                "type": "Role -> Attribute msg"
            }
        ],
        "binops": []
    },
